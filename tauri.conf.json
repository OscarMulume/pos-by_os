{
    "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/.schema/config.json",
    "productName": "POS Pro",
    "version": "1.0.0",
    "identifier": "com.pospro.app",
    "build": {
        "frontendDist": "../public",
        "devUrl": "http://localhost:8000",
        "beforeDevCommand": "php artisan serve --host=0.0.0.0 --port=8000",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "title": "POS Pro — Système de Caisse",
        "windows": [
            {
                "title": "POS Pro",
                "width": 1280,
                "height": 800,
                "minWidth": 1024,
                "minHeight": 768,
                "resizable": true,
                "fullscreen": false,
                "decorations": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["msi", "deb", "app"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/256x256.png"
        ]
    },
    "plugins": {
        "shell": {
            "open": true
        }
    }
}
